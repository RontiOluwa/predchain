# ─── Database ────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:password@localhost:5432/predchain"

# ─── AI Provider ─────────────────────────────────────────────────
OPENAI_API_KEY="sk-..."
# Alternatively use Anthropic:
# ANTHROPIC_API_KEY="sk-ant-..."

# ─── Blockchain ──────────────────────────────────────────────────
# Base Sepolia testnet RPC (get from Alchemy: https://alchemy.com)
RPC_URL="https://base-sepolia.g.alchemy.com/v2/YOUR_API_KEY"
CHAIN_ID="84532"

# Deployer wallet private key (NEVER use a wallet with real funds)
DEPLOYER_PRIVATE_KEY="0x..."

# Deployed contract addresses (filled after running deploy script)
FACTORY_CONTRACT_ADDRESS=""
PRED_TOKEN_ADDRESS=""

# ─── Chainlink ───────────────────────────────────────────────────
# ETH/USD price feed on Base Sepolia
CHAINLINK_ETH_USD_FEED="0x4aDC67696bA383F43DD60A9e78F2C97Fbbfc7cb1"

# ─── Queue (Redis) ────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ─── API Gateway ─────────────────────────────────────────────────
API_PORT="3001"
JWT_SECRET="change-this-to-a-random-64-char-string-in-production"

# ─── Environment ─────────────────────────────────────────────────
NODE_ENV="development"
